                }
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Godot: Import Project",
            "type": "shell",
            "command": "${env:GODOT}",
            "args": [
                "--headless",
                "--import",
                "--path", "."
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
